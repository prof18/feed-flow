<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.prof18.feed_flow</id>
  
  <name>Feed Flow</name>
  <summary>A Multiplatform RSS Reader</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Apache-2.0</project_license>
  
  <description>
    <p>
      Feed Flow is a modern, multiplatform RSS reader designed to keep you updated with your favorite news sources and blogs. 
      It offers a clean and intuitive interface, ensuring a seamless reading experience across your devices.
    </p>
    <ul>
      <li>Supports multiple accounts (e.g., local, Feedly, Inoreader - check current app features for accuracy)</li>
      <li>Offline reading capabilities</li>
      <li>Customizable interface</li>
      <li>OPML import/export</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">io.github.prof18.feed_flow.desktop</launchable>
  
