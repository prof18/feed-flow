{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "groupName": "Kotlin, KSP, SKIE",
      "groupSlug": "kotlin",
      "matchPackageNames": [
        "com.google.devtools.ksp",
        "org.jetbrains.kotlin",
        "co.touchlab.skie"
      ]
    },
    {
      "matchPackageNames": [
        "com.feedflow.detekt:com.feedflow.detekt.gradle.plugin",
        "com.feedflow.library:com.feedflow.library.gradle.plugin",
        "com.github.prof18:lyricist"
      ],
      "enabled": false
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["iosApp/project.yml"],
      "groupName": "iOS SPM packages",
      "groupSlug": "ios-spm"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "XcodeGen SPM packages in iosApp/project.yml",
      "fileMatch": ["^iosApp/project\\.yml$"],
      "matchStrings": [
        "url:\\s*https?://github\\.com/(?<depName>[^/\\s]+/[^/\\s]+?)(?:\\.git)?\\s*\\n\\s*exactVersion:\\s*(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Mint dependencies in iosApp/Mintfile",
      "fileMatch": ["^iosApp/Mintfile$"],
      "matchStrings": [
        "(?<depName>[^/\\s]+/[^/\\s@]+)@(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ]
}
